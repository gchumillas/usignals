{
  "name": "@gchumillas/usignals",
  "version": "0.1.0-alpha",
  "description": "A tiny, dependency-free reactive signals library for JavaScript/TypeScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "keywords": [
    "signals",
    "reactive",
    "reactivity",
    "state-management",
    "typescript"
  ],
  "author": "gchumillas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gchumillas/usignals.git"
  },
  "homepage": "https://github.com/gchumillas/usignals#readme",
  "bugs": {
    "url": "https://github.com/gchumillas/usignals/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean && node scripts/hide-internal-params.mjs",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "happy-dom": "^20.11.1",
    "husky": "^9.1.7",
    "jsx-dom": "^8.1.6",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "udomdiff": "^1.1.2"
  }
}
